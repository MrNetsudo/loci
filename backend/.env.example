# ============================================================
# Hereya Backend — Environment Variables
# Copy to .env and fill in all values before running
# NEVER commit .env to git
# ============================================================

# App
NODE_ENV=development
PORT=3000
LOCI_APP_NAME=Hereya
LOCI_API_VERSION=v1

# Supabase
HEREYA_SUPABASE_URL=https://your-project.supabase.co
HEREYA_SUPABASE_ANON_KEY=your-anon-key
HEREYA_SUPABASE_SERVICE_KEY=your-service-role-key

# Database (direct connection for migrations)
LOCI_DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Google Maps (Geofencing)
LOCI_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Foursquare (Venue Data)
HEREYA_FOURSQUARE_API_KEY=your-foursquare-key
HEREYA_FOURSQUARE_CLIENT_ID=your-foursquare-client-id
HEREYA_FOURSQUARE_CLIENT_SECRET=your-foursquare-client-secret

# OpenAI (Content Moderation)
HEREYA_OPENAI_API_KEY=your-openai-key
HEREYA_MODERATION_THRESHOLD=0.85

# Rate Limiting
LOCI_RATE_LIMIT_WINDOW_MS=60000
LOCI_RATE_LIMIT_MAX=120
LOCI_AUTH_RATE_LIMIT_MAX=10
LOCI_PRESENCE_RATE_LIMIT_MAX=1
LOCI_MESSAGE_RATE_LIMIT_MAX=30

# Room Settings
HEREYA_ROOM_COOLING_MINUTES=15
LOCI_MESSAGE_RETENTION_DAYS=30
LOCI_PRESENCE_TTL_HOURS=1

# Geofencing Defaults
LOCI_DEFAULT_GEOFENCE_RADIUS_M=100
LOCI_STADIUM_GEOFENCE_RADIUS_M=300

# JWT (Supabase handles this, but keep for reference)
HEREYA_JWT_SECRET=your-supabase-jwt-secret

# Logging
LOCI_LOG_LEVEL=debug
