{
  "expo": {
    "name": "Hereya",
    "slug": "hereya",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hereya",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.netsudo.hereya",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Hereya needs your location to find venues near you and put you in the right chat room.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Hereya uses your location to keep you in the venue chat room while you're there."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.netsudo.hereya",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Hereya uses your location to find your venue."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
